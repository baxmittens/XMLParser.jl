<?xml version="1.0" encoding="ISO-8859-1"?>
<OpenGeoSysProject>
    <meshes>
        <mesh>Matrix_fracture.vtu</mesh>
        <mesh>hydraulic_properties_r01.vtu</mesh>
        <mesh>OuterBounds_TopHigh.vtu</mesh>
        <mesh>OuterBounds_TopSlope.vtu</mesh>
        <mesh>OuterBounds_TopLow.vtu</mesh>
        <mesh>SRC_repo_mesh.vtu</mesh>
        <!-- <mesh>drifts.vtu</mesh> -->
    </meshes>
    <processes>
        <process>
            <name>HC</name>
            <type>ComponentTransport</type>
            <integration_order>2</integration_order>
            <coupling_scheme>staggered</coupling_scheme>
            <process_variables>
                <!--<process_variable>pressure</process_variable>-->
                <concentration>Tracer_IRF</concentration>
                <concentration>Tracer_CR</concentration>
                <concentration>Tracer_DC</concentration>
                <concentration>Tracer_SR</concentration>
                <pressure>pressure</pressure>
            </process_variables>
            <!-- <specific_body_force>0 0 -9.81</specific_body_force> -->
            <specific_body_force>0 0 0</specific_body_force>
            <secondary_variables>
                <secondary_variable internal_name="darcy_velocity" output_name="darcy_velocity"/>
            </secondary_variables>
            <aperture_size>
                <parameter>plane_thickness</parameter>
            </aperture_size>
            <!--non_advective_form>true</non_advective_form-->
            <!-- <numerical_stabilization>
                <type>FullUpwind</type>
                <cutoff_velocity>1e-8</cutoff_velocity>
            </numerical_stabilization> -->
            <numerical_stabilization>
                <type>IsotropicDiffusion</type>
                <tuning_parameter>0.25</tuning_parameter>
                <cutoff_velocity>1.e-8</cutoff_velocity>
            </numerical_stabilization>
        </process>
    </processes>
    <media>
        <medium id="0,1">
            <phases>
                <phase>
                    <type>AqueousLiquid</type>
